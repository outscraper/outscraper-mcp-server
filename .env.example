OUTSCRAPER_API_KEY=your_outscraper_api_key_here

# Optional: override if you need a different Outscraper API base URL.
OUTSCRAPER_API_BASE_URL=https://api.outscraper.cloud

# Optional: hosted mode.
# When true, HTTP requests can provide the API key in Authorization: Bearer ... or X-API-KEY / X-OUTSCRAPER-API-KEY.
CLOUD_SERVICE=false

# Optional: switch from stdio to stateless Streamable HTTP.
HTTP_STREAMABLE_SERVER=false

# Optional: local stateful HTTP/SSE mode with session management.
SSE_LOCAL=false
HTTP_STATEFUL_SERVER=false

HOST=localhost
PORT=3000
